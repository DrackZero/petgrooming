# ─── Servidor ───────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Base de datos PostgreSQL ───────────────
# Opción 1: cadena completa (Render / Neon / Supabase)
DATABASE_URL=postgresql://usuario:password@localhost:5432/petgrooming
# Opción 2: variables sueltas (se usan si no hay DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=petgrooming

# ─── Autenticación JWT ──────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ─── Email (Resend) ─────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=PetGrooming <no-reply@tudominio.com>

# ─── Pasarela de pagos ──────────────────────
PAYMENT_API_KEY=sk_test_xxxxxxxxxxxxxxxx
PAYMENT_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
